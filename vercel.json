{
  "services": {
    "frontend": {
      "root": "frontend/"
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "main.py"
    }
  },
  "rewrites": [
    {
      "source": "/auth:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/hostel:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/lab:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/orchestrator:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/admission:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/admin:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/health:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/docs:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/redoc:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/openapi.json:path*",
      "destination": { "service": "backend" }
    },
    {
      "source": "/:path*",
      "destination": { "service": "frontend" }
    }
  ]
}
